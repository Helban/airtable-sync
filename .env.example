# Copy this file to .env and fill in your own values.
# .env holds a secret token and is git-ignored. Never commit it.

# Personal access token from https://airtable.com/create/tokens (starts with "pat").
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX

# Base id from the browser URL when the base is open: airtable.com/appXXXX/...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Table the connector writes to. The setup script creates it if missing.
AIRTABLE_TABLE_NAME=Crypto
